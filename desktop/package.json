{
  "name": "agentshell-desktop",
  "version": "1.0.0",
  "description": "Desktop AI Agent for Windows PC Control",
  "main": "electron-main.js",
  "homepage": "./",
  "author": "AgentFrame Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run react-dev\" \"npm run electron-dev\"",
    "react-dev": "react-scripts start",
    "react-build": "react-scripts build",
    "electron-dev": "wait-on http://localhost:3000 && electron .",
    "electron-build": "electron-builder",
    "build": "npm run react-build && electron-builder",
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.6.2",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.4.5",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.0",
    "electron": "^25.8.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.29",
    "react-scripts": "5.0.1",
    "tailwindcss": "^3.3.3",
    "typescript": "^4.9.5",
    "wait-on": "^7.0.1"
  },
  "build": {
    "appId": "com.agentshell.desktop",
    "productName": "AgentShell Desktop",
    "files": [
      "build",
      "electron-main.js",
      "preload.js",
      "node_modules",
      "package.json"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
